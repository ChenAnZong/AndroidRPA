<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    >
    <data>
        <import type="android.view.View"/>
        <variable
            name="yyp"
            type="pyengine.YyProject" />
    </data>

    <com.google.android.material.card.MaterialCardView
        android:clickable="true"
        android:focusable="true"
        android:checkable="true"
        app:cardCornerRadius="7dp"
        android:layout_marginVertical="4dp"
        android:layout_height="wrap_content"
        android:layout_width="match_parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="6dp"
            android:paddingBottom="4dp"
            android:background="@color/primary_lay4"
            android:shadowRadius="10"
            android:id="@+id/yyp_row"
            android:shadowColor="@color/black">

            <TextView
                android:id="@+id/yyp_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:layout_marginHorizontal="6dp"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:layout_marginLeft="10dp"
                android:textColor="@color/colorPrimary"
                android:textStyle="bold"
                android:text="@{yyp.name}">
            </TextView>

            <TextView
                android:id="@+id/yyp_version"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="5dp"
                android:layout_marginBottom="4dp"
                android:fontFamily="sans-serif-light"
                app:layout_constraintLeft_toLeftOf="parent"
                android:textColor="@color/colorPrimary"
                android:layout_marginLeft="10dp"
                app:layout_constraintTop_toBottomOf="@id/yyp_name"
                android:text="@{yyp.lastDate + `  V` + yyp.version}">
            </TextView>

            <ImageView
                android:layout_gravity="center"
                android:id="@+id/image_icon_config"
                android:src="@drawable/ic_settings"
                android:layout_marginHorizontal="30dp"
                android:layout_width="20dp"
                android:layout_height="20dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintRight_toLeftOf="@id/image_icon_con"
                />

            <ImageView
                android:layout_gravity="center"
                android:id="@+id/image_icon_con"
                android:src="@drawable/ic_start"
                android:layout_marginHorizontal="5dp"
                android:layout_width="20dp"
                android:layout_height="20dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/image_icon_more"
                />

            <ImageView
                android:layout_gravity="center"
                android:id="@+id/image_icon_more"
                android:src="@drawable/ic_more_vert"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:padding="2dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginEnd="4dp"
                />

<!--            <com.google.android.material.switchmaterial.SwitchMaterial-->
<!--                android:id="@+id/app_root_switch"-->
<!--                android:layout_width="wrap_content"-->
<!--                android:layout_height="wrap_content"-->
<!--                android:layout_marginLeft="24dp"-->
<!--                android:layout_marginTop="10dp"-->
<!--                android:visibility="gone"-->
<!--                android:checked="@{app.hook}"-->
<!--                android:shadowColor="@color/colorPrimary"-->
<!--                android:shadowRadius="5"-->
<!--                app:useMaterialThemeColors="true"-->
<!--                android:text=""-->
<!--                android:gravity="end"-->
<!--                app:layout_constraintRight_toRightOf="parent"-->
<!--                app:layout_constraintTop_toTopOf="parent" />-->


        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

</layout>