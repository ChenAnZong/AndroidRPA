<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:paddingBottom="28dp">

    <!-- 拖拽条 -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="4dp"
        android:background="@drawable/bg_drag_handle" />

    <!-- 标题 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="8dp"
        android:paddingBottom="12dp">

        <ImageView
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:src="@drawable/ic_launch"
            app:tint="#EF6C00" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="@string/home_beginner_guide"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A" />

    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingBottom="14dp"
        android:text="@string/guide_intro"
        android:textSize="13sp"
        android:textColor="#888888"
        android:lineSpacingExtra="3dp" />

    <!-- ===== Step 1 ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingVertical="10dp"
        android:gravity="top">

        <TextView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:gravity="center"
            android:text="1"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="@drawable/bg_guide_step_number" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/guide_step1_title"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="@string/guide_step1_desc"
                android:textSize="12sp"
                android:textColor="#888888"
                android:lineSpacingExtra="2dp" />

        </LinearLayout>
    </LinearLayout>

    <!-- ===== Step 2 ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingVertical="10dp"
        android:gravity="top">

        <TextView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:gravity="center"
            android:text="2"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="@drawable/bg_guide_step_number" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/guide_step2_title"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="@string/guide_step2_desc"
                android:textSize="12sp"
                android:textColor="#888888"
                android:lineSpacingExtra="2dp" />

        </LinearLayout>
    </LinearLayout>

    <!-- ===== Step 3 ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingVertical="10dp"
        android:gravity="top">

        <TextView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:gravity="center"
            android:text="3"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="@drawable/bg_guide_step_number" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/guide_step3_title"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="@string/guide_step3_desc"
                android:textSize="12sp"
                android:textColor="#888888"
                android:lineSpacingExtra="2dp" />

        </LinearLayout>
    </LinearLayout>

    <!-- ===== Step 4 ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingVertical="10dp"
        android:gravity="top">

        <TextView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:gravity="center"
            android:text="4"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="@drawable/bg_guide_step_number" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/guide_step4_title"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="@string/guide_step4_desc"
                android:textSize="12sp"
                android:textColor="#888888"
                android:lineSpacingExtra="2dp" />

        </LinearLayout>
    </LinearLayout>

    <!-- ===== Step 5 ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingVertical="10dp"
        android:gravity="top">

        <TextView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:gravity="center"
            android:text="5"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="@drawable/bg_guide_step_number" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/guide_step5_title"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="@string/guide_step5_desc"
                android:textSize="12sp"
                android:textColor="#888888"
                android:lineSpacingExtra="2dp" />

        </LinearLayout>
    </LinearLayout>

    <!-- 分隔线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="8dp"
        android:background="#F0F0F0" />

    <!-- 底部按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingTop="14dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/btn_guide_doc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/guide_view_docs"
            android:textSize="14sp"
            android:textColor="@color/primary_lay_thin"
            android:gravity="center"
            android:padding="10dp"
            android:background="?attr/selectableItemBackground" />

        <View
            android:layout_width="1dp"
            android:layout_height="20dp"
            android:background="#E0E0E0" />

        <TextView
            android:id="@+id/btn_guide_dismiss"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/guide_dismiss"
            android:textSize="14sp"
            android:textColor="#999999"
            android:gravity="center"
            android:padding="10dp"
            android:background="?attr/selectableItemBackground" />

    </LinearLayout>

</LinearLayout>
