<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingBottom="24dp">

    <!-- 拖动条 -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="16dp"
        android:background="#DDDDDD"
        android:layout_margin="0dp" />

    <!-- 标题行 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="16dp">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_agent"
            android:layout_marginEnd="10dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/agent_help_title"
            android:textSize="17sp"
            android:textColor="@color/primary_lay"
            android:textStyle="bold" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#E0E0E0"
        android:layout_marginBottom="16dp" />

    <!-- 第一步 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="14dp">

        <TextView
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:text="1"
            android:textSize="13sp"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/bg_step_circle"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="1dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/agent_help_step1_title"
                android:textSize="14sp"
                android:textColor="@color/primary_lay"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/agent_help_step1_desc"
                android:textSize="13sp"
                android:textColor="@color/gray"
                android:layout_marginTop="2dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- 第二步 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="14dp">

        <TextView
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:text="2"
            android:textSize="13sp"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/bg_step_circle"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="1dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/agent_help_step2_title"
                android:textSize="14sp"
                android:textColor="@color/primary_lay"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/agent_help_step2_desc"
                android:textSize="13sp"
                android:textColor="@color/gray"
                android:layout_marginTop="2dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- 第三步 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="14dp">

        <TextView
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:text="3"
            android:textSize="13sp"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/bg_step_circle"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="1dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/agent_help_step3_title"
                android:textSize="14sp"
                android:textColor="@color/primary_lay"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/agent_help_step3_desc"
                android:textSize="13sp"
                android:textColor="@color/gray"
                android:layout_marginTop="2dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- 第四步 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="16dp">

        <TextView
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:text="4"
            android:textSize="13sp"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/bg_step_circle"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="1dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/agent_help_step4_title"
                android:textSize="14sp"
                android:textColor="@color/primary_lay"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/agent_help_step4_desc"
                android:textSize="13sp"
                android:textColor="@color/gray"
                android:layout_marginTop="2dp" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#E0E0E0"
        android:layout_marginBottom="16dp" />

    <!-- 提示条 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💡"
            android:textSize="14sp"
            android:layout_marginEnd="8dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/agent_help_tip"
            android:textSize="12sp"
            android:textColor="@color/gray" />
    </LinearLayout>

    <!-- 关闭按钮 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnHelpClose"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="8dp"
        android:text="@string/agent_help_close"
        android:textSize="14sp"
        app:cornerRadius="4dp"
        app:backgroundTint="@color/primary_lay" />

</LinearLayout>
