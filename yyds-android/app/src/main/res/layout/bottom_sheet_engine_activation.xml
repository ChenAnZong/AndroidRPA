<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:paddingBottom="24dp">

    <!-- 顶部拖拽指示条 -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/bg_drag_handle" />

    <!-- 标题区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_problem"
            app:tint="#E65100" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="@string/activation_title"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A" />
    </LinearLayout>

    <!-- 状态描述 -->
    <TextView
        android:id="@+id/tv_activation_desc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingTop="4dp"
        android:paddingBottom="12dp"
        android:text="@string/activation_desc"
        android:textSize="14sp"
        android:textColor="#666666"
        android:lineSpacingExtra="3dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginHorizontal="16dp"
        android:background="#F0F0F0" />

    <!-- 方案1: ROOT -->
    <LinearLayout
        android:id="@+id/option_root"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingVertical="14dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:background="@drawable/bg_option_icon_green">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_check"
                app:tint="@android:color/white" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/activation_root_title"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/activation_root_desc"
                android:textSize="12sp"
                android:textColor="#999999" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_root_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/activation_root_status"
            android:textSize="12sp"
            android:textColor="#E65100"
            android:background="@drawable/bg_status_badge_warn"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp" />
    </LinearLayout>

    <!-- 方案2: Shizuku -->
    <LinearLayout
        android:id="@+id/option_shizuku"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingVertical="14dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:background="@drawable/bg_option_icon_blue">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_tip"
                app:tint="@android:color/white" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/activation_shizuku_title"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/activation_shizuku_desc"
                android:textSize="12sp"
                android:textColor="#999999" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_shizuku_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/activation_shizuku_status"
            android:textSize="12sp"
            android:textColor="#E65100"
            android:background="@drawable/bg_status_badge_warn"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp" />
    </LinearLayout>

    <!-- 方案3: ADB -->
    <LinearLayout
        android:id="@+id/option_adb"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingVertical="14dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:background="@drawable/bg_option_icon_purple">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_console"
                app:tint="@android:color/white" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/activation_adb_title"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/activation_adb_desc"
                android:textSize="12sp"
                android:textColor="#999999" />
        </LinearLayout>

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_open_in_new"
            app:tint="#BBBBBB" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="4dp"
        android:background="#F0F0F0" />

    <!-- 底部提示 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingTop="12dp"
        android:text="@string/activation_hint"
        android:textSize="13sp"
        android:textColor="#AAAAAA"
        android:gravity="center" />

</LinearLayout>
