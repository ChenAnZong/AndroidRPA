<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/floating_item_bg"
    android:paddingHorizontal="12dp"
    android:paddingVertical="10dp"
    android:layout_marginBottom="6dp"
    android:gravity="center_vertical">

    <!-- Project info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginEnd="8dp">

        <TextView
            android:id="@+id/item_project_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/floating_item_name"
            android:textColor="#264B6F"
            android:textSize="14sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="3dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/item_project_version"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="V1.0"
                android:textColor="#999999"
                android:textSize="11sp" />

            <View
                android:layout_width="1dp"
                android:layout_height="10dp"
                android:layout_marginHorizontal="6dp"
                android:background="#DDDDDD" />

            <TextView
                android:id="@+id/item_project_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/floating_item_pending"
                android:textColor="#999999"
                android:textSize="11sp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Action button -->
    <FrameLayout
        android:id="@+id/item_action_btn"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/floating_btn_start">

        <ImageView
            android:id="@+id/item_action_icon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_play_arrow_white" />

    </FrameLayout>

</LinearLayout>
