<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet">

    <!-- 拖拽指示条 -->
    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="6dp"
        android:background="@drawable/bg_sheet_handle" />

    <!-- 标题 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingTop="4dp"
        android:paddingBottom="12dp"
        android:text="@string/import_title"
        android:textColor="#264B6F"
        android:textSize="15sp"
        android:textStyle="bold" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginHorizontal="16dp"
        android:background="#E0E0E0" />

    <!-- 选择文件导入 -->
    <LinearLayout
        android:id="@+id/menuPickFile"
        style="@style/SheetMenuItem">
        <ImageView
            style="@style/SheetMenuIcon"
            android:src="@drawable/ic_file_zip" />
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                style="@style/SheetMenuText"
                android:text="@string/import_pick_file" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#ACACAC"
                android:textSize="12sp"
                android:text="@string/import_pick_file_desc" />
        </LinearLayout>
    </LinearLayout>

    <!-- 扫描常用目录 -->
    <LinearLayout
        android:id="@+id/menuScanFolders"
        style="@style/SheetMenuItem">
        <ImageView
            style="@style/SheetMenuIcon"
            android:src="@drawable/ic_folder_scan" />
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                style="@style/SheetMenuText"
                android:text="@string/import_scan_folders" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#ACACAC"
                android:textSize="12sp"
                android:text="@string/import_scan_folders_desc" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="16dp" />

</LinearLayout>
