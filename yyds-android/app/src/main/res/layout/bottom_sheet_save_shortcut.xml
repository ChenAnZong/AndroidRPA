<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/bg_bottom_sheet">

    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:background="@drawable/bg_sheet_handle"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⚡ 保存为快捷指令"
        android:textSize="16sp"
        android:textColor="@color/primary_lay"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="快捷指令名称"
        android:textSize="13sp"
        android:textColor="@color/gray"
        android:layout_marginBottom="6dp" />

    <EditText
        android:id="@+id/etShortcutTitle"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/bg_input_outline"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:textSize="14sp"
        android:textColor="@color/primary_lay"
        android:hint="输入名称"
        android:inputType="text"
        android:maxLines="1"
        android:layout_marginBottom="20dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnShortcutCancel"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="取消"
            android:textColor="@color/gray"
            android:textSize="14sp"
            android:layout_marginEnd="8dp"
            app:cornerRadius="8dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:strokeColor="#DDDDDD" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnShortcutSave"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="保存"
            android:textSize="14sp"
            app:cornerRadius="8dp"
            app:backgroundTint="@color/primary_lay" />
    </LinearLayout>

    <View android:layout_width="0dp" android:layout_height="8dp" />
</LinearLayout>
