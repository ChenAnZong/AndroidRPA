<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/agent_overlay_root"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_agent_overlay"
    android:minWidth="220dp"
    android:maxWidth="320dp">

    <!-- 顶部状态色条（颜色随 show/think/done 状态动态变化） -->
    <View
        android:id="@+id/agent_accent_bar"
        android:layout_width="match_parent"
        android:layout_height="2.5dp"
        android:background="#5B9CF6" />

    <!-- 内容容器 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="14dp"
        android:paddingTop="10dp"
        android:paddingBottom="12dp">

        <!-- 标题行：脉冲点 + 标题 + 关闭 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- 脉冲指示点 -->
            <View
                android:id="@+id/agent_pulse_dot"
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:background="@drawable/bg_pulse_dot" />

            <TextView
                android:id="@+id/agent_overlay_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="AI Agent"
                android:textColor="#B0BEC5"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.03"
                android:singleLine="true" />

            <!-- 关闭按钮（加大热区） -->
            <TextView
                android:id="@+id/agent_overlay_close"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:gravity="center"
                android:text="✕"
                android:textColor="#50FFFFFF"
                android:textSize="13sp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="close" />
        </LinearLayout>

        <!-- 分隔线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:background="#12FFFFFF" />

        <!-- 主内容区 -->
        <TextView
            android:id="@+id/agent_overlay_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#E8E8E8"
            android:textSize="12.5sp"
            android:fontFamily="sans-serif"
            android:lineSpacingExtra="3dp"
            android:maxLines="5"
            android:ellipsize="end" />

    </LinearLayout>

</LinearLayout>
