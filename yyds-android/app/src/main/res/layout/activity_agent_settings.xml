<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary"
    android:fitsSystemWindows="true"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="32dp">

        <!-- ========== 服务商选择卡片 ========== -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="4dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- 标题 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/agent_provider_title"
                    android:textColor="@color/primary_lay"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium" />

                <!-- 服务商 Spinner -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AI 服务商"
                    android:textColor="#666666"
                    android:textSize="13sp"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="6dp" />

                <Spinner
                    android:id="@+id/spinnerProvider"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_spinner_outline"
                    android:paddingHorizontal="12dp"
                    android:popupBackground="#FFFFFF"
                    android:spinnerMode="dropdown" />

                <!-- 服务商提示 -->
                <TextView
                    android:id="@+id/tvProviderHint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/agent_hint_autoglm"
                    android:textColor="#999999"
                    android:textSize="12sp"
                    android:layout_marginTop="6dp" />

                <!-- 模型 Spinner -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/agent_model_title"
                    android:textColor="#666666"
                    android:textSize="13sp"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="6dp" />

                <Spinner
                    android:id="@+id/spinnerModel"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_spinner_outline"
                    android:paddingHorizontal="12dp"
                    android:popupBackground="#FFFFFF"
                    android:spinnerMode="dropdown" />

                <!-- 自定义模型名输入（选"自定义模型名..."时显示） -->
                <EditText
                    android:id="@+id/etCustomModel"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_input_outline_focused"
                    android:hint="@string/agent_custom_model_hint"
                    android:textColorHint="#AAAAAA"
                    android:textColor="@color/primary_lay"
                    android:textSize="14sp"
                    android:paddingHorizontal="12dp"
                    android:singleLine="true"
                    android:visibility="gone"
                    android:layout_marginTop="8dp"
                    android:fontFamily="sans-serif-condensed" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ========== API Key 卡片 ========== -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="4dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="API Key"
                    android:textColor="@color/primary_lay"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium" />

                <!-- API Key 输入 -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:boxCornerRadiusTopStart="4dp"
                    app:boxCornerRadiusTopEnd="4dp"
                    app:boxCornerRadiusBottomStart="4dp"
                    app:boxCornerRadiusBottomEnd="4dp"
                    app:boxStrokeColor="@color/primary_lay"
                    app:hintTextColor="@color/primary_lay"
                    app:passwordToggleEnabled="true"
                    app:passwordToggleTint="@color/gray"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etApiKey"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/agent_input_apikey"
                        android:inputType="textPassword"
                        android:textColor="@color/primary_lay"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-condensed" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- 自定义 Base URL（仅 custom 显示） -->
                <LinearLayout
                    android:id="@+id/layoutCustomConfig"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:boxCornerRadiusTopStart="4dp"
                        app:boxCornerRadiusTopEnd="4dp"
                        app:boxCornerRadiusBottomStart="4dp"
                        app:boxCornerRadiusBottomEnd="4dp"
                        app:boxStrokeColor="@color/primary_lay"
                        app:hintTextColor="@color/primary_lay"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etBaseUrl"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/agent_base_url_hint"
                            android:inputType="textUri"
                            android:textColor="@color/primary_lay"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-condensed" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <!-- 测试连接 -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnTestConnection"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="14dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:text="@string/agent_test_connection"
                    android:textColor="@color/primary_lay"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    app:strokeColor="@color/primary_lay"
                    app:strokeWidth="1dp"
                    app:cornerRadius="4dp" />

                <!-- 测试结果 -->
                <TextView
                    android:id="@+id/tvTestResult"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="@color/gray"
                    android:layout_marginTop="8dp"
                    android:visibility="gone" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ========== 高级选项卡片 ========== -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="4dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- 折叠头部 -->
                <LinearLayout
                    android:id="@+id/layoutAdvancedHeader"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/agent_show_advanced"
                        android:textColor="@color/primary_lay"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium" />

                    <ImageView
                        android:id="@+id/ivAdvancedArrow"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_arrow_down"
                        android:rotation="0"
                        app:tint="@color/gray" />
                </LinearLayout>

                <!-- 折叠内容 -->
                <LinearLayout
                    android:id="@+id/layoutAdvancedBody"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingBottom="16dp"
                    android:visibility="gone">

                    <!-- 最大执行步数 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="4dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/agent_max_steps"
                            android:textColor="@color/primary_lay"
                            android:textSize="14sp" />

                        <EditText
                            android:id="@+id/etMaxSteps"
                            android:layout_width="72dp"
                            android:layout_height="38dp"
                            android:background="@drawable/bg_input_outline"
                            android:gravity="center"
                            android:inputType="number"
                            android:text="25"
                            android:textColor="@color/primary_lay"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-condensed"
                            android:paddingHorizontal="8dp" />
                    </LinearLayout>

                    <!-- 分隔线 -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F0EEEC"
                        android:layout_marginVertical="6dp" />

                    <!-- UI 控件树增强 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:minHeight="52dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginEnd="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/agent_use_ui_dump"
                                android:textColor="@color/primary_lay"
                                android:textSize="14sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/agent_use_ui_dump_desc"
                                android:textColor="#999999"
                                android:textSize="12sp"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchUiDump"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            app:thumbTint="@color/primary_lay"
                            app:trackTintMode="src_atop" />
                    </LinearLayout>

                    <!-- 分隔线 -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F0EEEC"
                        android:layout_marginVertical="6dp" />

                    <!-- 动作反思 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:minHeight="52dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginEnd="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/agent_use_reflector"
                                android:textColor="@color/primary_lay"
                                android:textSize="14sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/agent_use_reflector_desc"
                                android:textColor="#999999"
                                android:textSize="12sp"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchReflector"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            app:thumbTint="@color/primary_lay"
                            app:trackTintMode="src_atop" />
                    </LinearLayout>

                    <!-- 分隔线 -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F0EEEC"
                        android:layout_marginVertical="6dp" />

                    <!-- 悬浮窗口显示执行过程 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:minHeight="52dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginEnd="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/agent_show_floating_window"
                                android:textColor="@color/primary_lay"
                                android:textSize="14sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/agent_show_floating_window_desc"
                                android:textColor="#999999"
                                android:textSize="12sp"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchFloatingWindow"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            app:thumbTint="@color/primary_lay"
                            app:trackTintMode="src_atop" />
                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>  
        </com.google.android.material.card.MaterialCardView>

        <!-- ========== 保存按钮 ========== -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:text="@string/agent_save_settings"
            android:textColor="@color/primary_lay"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            app:strokeColor="@color/primary_lay"
            app:strokeWidth="1dp"
            app:cornerRadius="4dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="24dp" />

    </LinearLayout>
</ScrollView>