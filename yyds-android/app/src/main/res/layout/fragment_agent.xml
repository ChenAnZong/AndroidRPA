<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/primary">

    <!-- 顶部 Hero 横幅 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardHero"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="4dp"
        app:cardElevation="0dp"
        android:layout_margin="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_agent_hero"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/nav_agent"
                    android:textSize="20sp"
                    android:textColor="@android:color/white"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/btnHelp"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:padding="4dp"
                    android:layout_marginEnd="4dp"
                    android:src="@drawable/ic_help"
                    app:tint="@android:color/white"
                    android:contentDescription="@string/agent_help_btn" />

                <ImageView
                    android:id="@+id/btnSettings"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:padding="4dp"
                    android:src="@drawable/ic_settings"
                    app:tint="@android:color/white"
                    android:contentDescription="@string/agent_settings" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvHeroSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/agent_hero_desc"
                android:textSize="13sp"
                android:textColor="#CCFFFFFF"
                android:layout_marginTop="4dp" />

            <!-- 状态指示 -->
            <LinearLayout
                android:id="@+id/layoutStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="10dp"
                android:visibility="gone">

                <View
                    android:id="@+id/viewStatusDot"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/bg_dot_blue" />

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/agent_running_status"
                    android:textSize="12sp"
                    android:textColor="#CCFFFFFF"
                    android:layout_marginStart="6dp" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- 未配置提示卡片 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardNotConfigured"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:cardCornerRadius="4dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        app:cardBackgroundColor="@android:color/white"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔑"
                android:textSize="36sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/agent_need_config"
                android:textSize="15sp"
                android:textColor="@color/primary_lay"
                android:textStyle="bold"
                android:layout_marginTop="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/agent_need_config_desc"
                android:textSize="13sp"
                android:textColor="@color/gray"
                android:gravity="center"
                android:layout_marginTop="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGoSettings"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="@string/agent_go_settings"
                android:textSize="14sp"
                app:cornerRadius="4dp"
                app:backgroundTint="@color/primary_lay"
                android:layout_marginTop="12dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- 欢迎引导卡片 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardWelcome"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:cardCornerRadius="4dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        app:cardBackgroundColor="@android:color/white"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/agent_welcome_title"
                android:textSize="16sp"
                android:textColor="@color/primary_lay"
                android:textStyle="bold"
                android:fontFamily="sans-serif-condensed" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/agent_welcome_desc"
                android:textSize="13sp"
                android:textColor="@color/gray"
                android:layout_marginTop="6dp" />

            <TextView
                android:id="@+id/tvExample1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/agent_welcome_example1"
                android:textSize="14sp"
                android:textColor="@color/primary_lay"
                android:fontFamily="sans-serif-condensed"
                android:background="?attr/selectableItemBackground"
                android:paddingVertical="10dp"
                android:layout_marginTop="12dp" />

            <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#E0E0E0" />

            <TextView
                android:id="@+id/tvExample2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/agent_welcome_example2"
                android:textSize="14sp"
                android:textColor="@color/primary_lay"
                android:fontFamily="sans-serif-condensed"
                android:background="?attr/selectableItemBackground"
                android:paddingVertical="10dp" />

            <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#E0E0E0" />

            <TextView
                android:id="@+id/tvExample3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/agent_welcome_example3"
                android:textSize="14sp"
                android:textColor="@color/primary_lay"
                android:fontFamily="sans-serif-condensed"
                android:background="?attr/selectableItemBackground"
                android:paddingVertical="10dp" />

            <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#E0E0E0" />

            <TextView
                android:id="@+id/tvExample4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/agent_welcome_example4"
                android:textSize="14sp"
                android:textColor="@color/primary_lay"
                android:fontFamily="sans-serif-condensed"
                android:background="?attr/selectableItemBackground"
                android:paddingVertical="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/agent_welcome_tip"
                android:textSize="12sp"
                android:textColor="@color/gray"
                android:layout_marginTop="12dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ④ 快捷指令横向滑动列表 -->
    <LinearLayout
        android:id="@+id/layoutShortcuts"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:layout_marginBottom="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="⚡ 快捷指令"
                android:textSize="12sp"
                android:textColor="@color/gray"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvShortcutsEdit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="管理"
                android:textSize="12sp"
                android:textColor="@color/primary_lay"
                android:padding="4dp"
                android:background="?attr/selectableItemBackground" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvShortcuts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:clipToPadding="false" />
    </LinearLayout>

    <!-- 设备查询答案气泡卡片（零token快速回答） -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardAnswer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:cardCornerRadius="4dp"
        app:cardElevation="2dp"
        app:strokeWidth="1dp"
        app:strokeColor="#D0E8FF"
        app:cardBackgroundColor="#EEF6FF"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🤖 AI 助手"
                    android:textSize="12sp"
                    android:textColor="#2C5F8A"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvAnswerBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚡ 即时回答"
                    android:textSize="11sp"
                    android:textColor="@android:color/white"
                    android:background="@drawable/bg_badge_primary"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvAnswer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="#1A1A1A"
                android:layout_marginTop="8dp"
                android:lineSpacingExtra="3dp"
                android:textIsSelectable="true" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ② 任务完成结果截图卡片 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardResultScreenshot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:cardCornerRadius="4dp"
        app:cardElevation="2dp"
        app:strokeWidth="1dp"
        app:strokeColor="#C8E6C9"
        app:cardBackgroundColor="#F1F8E9"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✅ 任务完成截图"
                android:textSize="12sp"
                android:textColor="#388E3C"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <ImageView
                android:id="@+id/imgResultScreenshot"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:scaleType="centerCrop"
                android:background="#EEEEEE" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Token 用量显示 -->
    <TextView
        android:id="@+id/tvTokenUsage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:textSize="12sp"
        android:textColor="@color/gray"
        android:visibility="gone"
        android:background="#F5F5F5" />

    <!-- 日志时间线区域 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvLogs"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:clipToPadding="false" />

    <!-- 底部输入区域 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="0dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/primary">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- 运行中的控制栏 -->
            <LinearLayout
                android:id="@+id/layoutRunningBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:visibility="gone"
                android:layout_marginBottom="8dp">

                <ProgressBar
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    style="?android:attr/progressBarStyleSmall" />

                <TextView
                    android:id="@+id/tvRunningAction"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/agent_executing"
                    android:textSize="13sp"
                    android:textColor="@color/gray"
                    android:layout_marginStart="8dp"
                    android:singleLine="true"
                    android:ellipsize="end" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStop"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="@string/agent_stop"
                    android:textColor="#F44336"
                    android:textSize="13sp"
                    app:cornerRadius="4dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    app:strokeColor="#F44336"
                    app:strokeWidth="1dp" />
            </LinearLayout>

            <!-- 输入框 + 发送按钮 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_agent_input"
                android:paddingStart="16dp"
                android:paddingEnd="4dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp">

                <EditText
                    android:id="@+id/etInstruction"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="@string/agent_input_hint"
                    android:textSize="14sp"
                    android:textColor="@color/primary_lay"
                    android:textColorHint="@color/gray"
                    android:background="@null"
                    android:minHeight="40dp"
                    android:maxLines="4"
                    android:inputType="textMultiLine" />

                <ImageView
                    android:id="@+id/btnSend"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="8dp"
                    android:src="@drawable/ic_send"
                    android:background="@drawable/bg_agent_send_btn"
                    app:tint="@android:color/white"
                    android:contentDescription="@string/agent_send" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
