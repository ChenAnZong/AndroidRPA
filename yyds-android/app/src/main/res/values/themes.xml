<resources xmlns:tools="http://schemas.android.com/tools"   xmlns:app="http://schemas.android.com/apk/res-auto">
    <style name="AppTheme" parent="Theme.MaterialComponents.Light">
        <!-- Primary brand color. -->
        <item name="colorPrimary">#FBF7F1</item>
        <item name="colorPrimaryVariant">#BD9E00</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryDark">@color/primary</item>
        <!-- Secondary brand color. -->
        <!-- Status bar color. -->
<!--        <item name="android:statusBarColor">@color/primary</item>-->

        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>

<!--        <item name="android:windowTranslucentNavigation">true</item>-->
        <!-- Customize your theme here. -->
        <item name="windowActionBar">true</item>
        <item name="windowNoTitle">true</item>

        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <style name="Active" parent="@style/Theme.AppCompat">
        <item name="android:textSize">18dp</item>
        <item name="colorPrimary">@color/primary_lay</item>
        <item name="android:textColorSecondary">@color/primary_lay</item>
    </style>

    <style name="MyMaterialButton" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/primary_lay</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="cornerRadius">4dp</item>
    </style>

    <style name="MyRadioButton" parent="Widget.Material3.CompoundButton.RadioButton">
        //red is the color of the pressed state and activated state
        <item name="colorControlActivated">@color/primary_lay</item>
        //black is the color of the normal state
        <item name="colorControlNormal">@android:color/darker_gray</item>
        <item name="colorOnSecondary">@color/primary_lay</item>
        <item name="colorSecondary">@color/primary_lay</item>
        <item name="colorAccent">@color/primary_lay</item>
        <item name="colorPrimary">@color/primary_lay</item>
        <item name="android:colorPressedHighlight">@color/primary_lay4</item>
        <item name="colorControlHighlight">@color/primary_lay</item>
    </style>

    <style name="TextInputLayoutStyle" parent="Widget.MaterialComponents.TextInputLayout.FilledBox.Dense">
        <item name="boxStrokeColor">@color/color_box_stroke</item>
    </style>

    <style name="BottomSheetDialogTheme" parent="Theme.MaterialComponents.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/BottomSheetStyle</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>

    <style name="BottomSheetStyle" parent="Widget.MaterialComponents.BottomSheet.Modal">
        <item name="shapeAppearanceOverlay">@style/BottomSheetShapeAppearance</item>
        <item name="android:background">@android:color/transparent</item>
    </style>

    <style name="BottomSheetShapeAppearance" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">14dp</item>
        <item name="cornerSizeTopRight">14dp</item>
    </style>

</resources>