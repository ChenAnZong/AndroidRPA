    "id": "set_alarm",
    "name": "设闹钟",
    "description": "设置闹钟或提醒",
    "category": "工具",
    "keywords": ["设闹钟", "闹钟", "提醒我", "定时", "叫我起床"],
    "params": [
      {
        "name": "time",
        "type": "string",
        "description": "时间",
        "required": true,
        "examples": ["7点", "明早8点", "下午3点"]
      }
    ],
    "related_apps": [
      {
        "package": "com.android.deskclock",
        "name": "时钟",
        "type": "delegation",
        "priority": 100,
        "deep_link": "",
        "steps": [],
        "python_snippet": "# 通过 Intent 设置闹钟\nimport re\ntime_str = '{time}'\nhour = 7\nminute = 0\nm = re.search(r'(\\d+)[点时](\\d*)', time_str)\nif m:\n    hour = int(m.group(1))\n    minute = int(m.group(2)) if m.group(2) else 0\nif '下午' in time_str or '晚' in time_str:\n    hour += 12\nshell(f'am start -a android.intent.action.SET_ALARM --ei android.intent.extra.alarm.HOUR {hour} --ei android.intent.extra.alarm.MINUTES {minute} --ez android.intent.extra.alarm.SKIP_UI false')\nresult = f'已设置 {hour}:{minute:02d} 的闹钟'"
      }
    ]
  },
