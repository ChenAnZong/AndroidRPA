    "id": "system_settings",
    "name": "系统设置",
    "description": "修改系统设置（WiFi、蓝牙、亮度等）",
    "category": "系统",
    "keywords": ["设置", "WiFi", "蓝牙", "亮度", "音量", "飞行模式", "热点"],
    "params": [
      {
        "name": "setting",
        "type": "string",
        "description": "要修改的设置项",
        "required": true,
        "examples": ["WiFi", "蓝牙", "亮度"]
      }
    ],
    "related_apps": [
      {
        "package": "com.android.settings",
        "name": "设置",
        "type": "delegation",
        "priority": 100,
        "deep_link": "",
        "steps": [],
        "python_snippet": "# Root 权限直接修改系统设置\nsetting = '{setting}'.lower()\nif 'wifi' in setting:\n    # 切换 WiFi\n    state = root_shell('settings get global wifi_on').strip()\n    new_state = '0' if state == '1' else '1'\n    root_shell(f'svc wifi {\"enable\" if new_state == \"1\" else \"disable\"}')\n    result = f'WiFi 已{\"开启\" if new_state == \"1\" else \"关闭\"}'\nelif '蓝牙' in setting or 'bluetooth' in setting:\n    root_shell('svc bluetooth enable')\n    result = '蓝牙已开启'\nelif '亮度' in setting:\n    root_shell('settings put system screen_brightness 128')\n    result = '亮度已设置为中等'\nelif '飞行' in setting:\n    state = root_shell('settings get global airplane_mode_on').strip()\n    new_val = '0' if state == '1' else '1'\n    root_shell(f'settings put global airplane_mode_on {new_val}')\n    result = f'飞行模式已{\"开启\" if new_val == \"1\" else \"关闭\"}'\nelse:\n    shell('am start -a android.settings.SETTINGS')\n    result = '已打开系统设置'"
      }
    ]
  }
